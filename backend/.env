# ============================================================
# MediNLP Backend Environment Configuration
# ============================================================

# Optional: Model file paths (defaults to model_files/ directory)
# MODEL_DIR=./model_files
# MODEL_PATH=./model_files/final_multinomial_nb_model.joblib
# FEATURE_PATH=./model_files/feature_names.joblib
# SYMPTOM_LIST_PATH=./model_files/symptom_feature_list.csv
# RECOMMENDATION_JSON_PATH=./model_files/disease_recommendation_lookup_minimal.json
# RED_FLAG_JSON_PATH=./model_files/red_flag_rules.json

# Optional: Prediction settings
TOP_K=3
ENABLE_SHAP=true
SHAP_NSAMPLES=100

# Nearby doctor/hospital search is handled by the frontend Google Maps text link.
# No Foursquare, Overpass, or hospital API key is needed.


# Login/chat restore database
# Set DB_PROVIDER=mysql after creating MySQL database/user.
# DB_PROVIDER=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=medinlp_chatbot
# AUTH_SECRET=change-this-secret-before-deployment
